# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here

# Gmail Configuration
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Settings
CHECK_INTERVAL=60
MAX_BODY_LENGTH=300
CHAT_ID=your_default_chat_id_here

# Filter Rules (JSON Array)
# Format: [{"name":"rule name","field":"from|subject","match":"keyword","chat_id":"chat_id"}]
# Example: [{"name":"Banking","field":"from","match":"bank","chat_id":"-1001234567890"}]
FILTER_RULES=[{"name":"All Emails","field":"from","match":"*","chat_id":"your_chat_id_here","priority":99,"enabled":true}]

# Timezone
TZ=Asia/Bangkok
